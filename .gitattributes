# Default: auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# PowerShell must keep CRLF on Windows working trees.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Common web/text formats: LF.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.csv   text eol=lf

# Binary - never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.docx  binary
*.zip   binary
